# Copy to .env.convex (gitignored) and fill in.
#
# These are the Convex BACKEND env vars. They live ON the Convex deployment (set with
# `bunx convex env set`), NOT in the SPA bundle. Convex env vars do NOT migrate between
# projects/deployments, so after a personal -> company project swap you must re-set them
# on the new deployment. Push them with:
#
#     bash scripts/convex-env-sync.sh --prod          # -> production deployment
#     bash scripts/convex-env-sync.sh                 # -> dev deployment
#   (equivalently: bunx convex env set --from-file .env.convex --prod)
#
# See docs/MIGRATION.md §C and docs/DEPLOY.md §4.

# --- Required: Feishu login + Bitable intake (DEPLOY.md §4, ADR-0010) ---
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=          # the base/<...> segment of the Base URL
FEISHU_BITABLE_TABLE_ID=           # the ?table=<...> param of the Base URL

# --- Optional ---
# FEISHU_BITABLE_WEB_BASE_URL=https://<tenant>.feishu.cn/base/<token>  # detail-link host
# FEISHU_DRIVE_UPLOAD_CONCURRENCY=4         # drive upload fan-out (default 4)
# BITABLE_OWNED_ROW_UPDATE_WINDOW_MS=       # deferred-fill ownership window (attachmentFill.ts)
# ATTACHMENT_CAP=10                         # backend mirror of VITE_ATTACHMENT_CAP
# BITABLE_DIAG_LOG=0                         # 1 = verbose bitable diagnostics
