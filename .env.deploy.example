# Copy to .env.deploy (gitignored) and fill in.
# Used by scripts/provision-ecs.sh (one-time host setup) and scripts/deploy.sh.

# Public host the SPA is served from (e.g. wmdev.zeuja.com). Single source of
# truth for the host: provision-ecs.sh renders the nginx server_name from it,
# deploy.sh frontend reports the deployed URL from it, and `bun run manifest:ecs`
# bakes it into the sideload manifest. No more hardcoded host in the scripts.
ADDIN_ECS_HOST=wmdev.zeuja.com

# ECS deploy target for scripts/deploy.sh (the steady-state `deploy` user).
# DEPLOY_SSH_KEY is a PATH to the private key whose public half lives in the
# deploy user's ~/.ssh/authorized_keys on the box (installed by provision-ecs.sh
# from DEPLOY_PUBKEY below). DEPLOY_HOST may be the domain or the box IP.
DEPLOY_HOST=__ADDIN_DOMAIN__
DEPLOY_USER=deploy
DEPLOY_SSH_KEY=~/.ssh/addin_deploy

# --- One-time provisioning (scripts/provision-ecs.sh) -----------------------
# Bootstrap SSH identity for a FRESH box: Aliyun's initial root over IP. This is
# deliberately NOT DEPLOY_USER/DEPLOY_SSH_KEY — the deploy user does not exist
# until provision-ecs.sh creates it. After provisioning, root login is disabled.
PROVISION_SSH_TARGET=root@__ADDIN_IP__
# Let's Encrypt registration + renewal-notice email (certbot --nginx -m).
CERTBOT_EMAIL=
# PUBLIC half of DEPLOY_SSH_KEY. provision-ecs.sh installs this into the deploy
# user's ~/.ssh/authorized_keys. Paste the whole line (e.g. the contents of
# ~/.ssh/addin_deploy.pub): "ssh-ed25519 AAAA... comment".
DEPLOY_PUBKEY=

# Convex prod deploy key
# Convex Dashboard -> Settings -> Deploy Keys -> Production
CONVEX_DEPLOY_KEY=

# Build-time vars baked into the SPA bundle by vite
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site
VITE_FEISHU_APP_ID=

# Feishu fallback auth server (ADR-0008), deployed by `deploy.sh auth` to the box's
# systemd EnvironmentFile (/etc/feishu-auth.env, chmod 600). Backend-only SECRET —
# NEVER put it in a VITE_* var (those ship to every browser in plaintext).
FEISHU_APP_SECRET=
# REQUIRED: the box's PUBLIC HTTPS domain callback — NOT the DEPLOY_HOST IP.
# Must equal the domain the SPA is served from AND the URL whitelisted in Feishu.
FEISHU_FALLBACK_REDIRECT_URI=https://__ADDIN_DOMAIN__/feishu/oauth/callback
# Optional — sensible defaults if unset:
#   FEISHU_APP_ID         defaults to VITE_FEISHU_APP_ID (same public value)
#   FEISHU_FALLBACK_SCOPE defaults to the SPA's least-privilege scope set
#   FEISHU_AUTH_PORT      defaults to 8788 (the local port nginx proxies to)
# FEISHU_FALLBACK_SCOPE=im:chat:readonly contact:user:search im:message offline_access
# FEISHU_AUTH_PORT=8788
