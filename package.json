{
  "name": "outlook-feishu-addin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "vite --mode outlook",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint --deny-warnings -D correctness -D suspicious -D pedantic -A require-unicode-regexp -A no-underscore-dangle --tsconfig tsconfig.app.json src/ convex/",
    "fmt": "oxlint --fix src/ convex/",
    "typecheck": "tsgo -b --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "manifest:global": "bun scripts/manifest.mjs --global --output manifest-sideload.xml",
    "manifest:ecs": "bun scripts/manifest.mjs --ecs --output manifest-sideload-cn.xml",
    "dev:all": "concurrently \"bunx convex dev\" \"bun run dev\"",
    "deploy:fe": "bash scripts/deploy.sh frontend",
    "deploy:be": "bash scripts/deploy.sh backend",
    "deploy:all": "bash scripts/deploy.sh all",
    "deploy:cf": "bash scripts/deploy.sh cloudflare",
    "doctor": "bunx react-doctor@latest",
    "search:experiment": "bun scripts/search-latency-experiment.mjs"
  },
  "dependencies": {
    "@emnapi/core": "^1.11.0",
    "@emnapi/runtime": "^1.11.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-slot": "^1.2.5",
    "@sentry/react": "^10.56.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.40.0",
    "lucide-react": "^1.17.0",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/office-js": "^1.0.592",
    "@types/office-runtime": "^1.0.37",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@typescript/native-preview": "^7.0.0-dev.20260608.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
