{
  "name": "outlook-feishu-addin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "vite --mode outlook",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint --deny-warnings -D correctness -D suspicious -D pedantic --tsconfig tsconfig.app.json src/ convex/",
    "fmt": "oxlint --fix src/ convex/",
    "typecheck": "tsgo -b --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "dev:all": "concurrently \"npx convex dev\" \"npm run dev\"",
    "deploy:fe": "bash scripts/deploy.sh frontend",
    "deploy:be": "bash scripts/deploy.sh backend",
    "deploy:all": "bash scripts/deploy.sh all",
    "deploy:cf": "bash scripts/deploy.sh cloudflare"
  },
  "dependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@fontsource/geist-sans": "^5.1.0",
    "@fontsource/instrument-serif": "^5.1.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-slot": "^1.1.1",
    "@sentry/react": "^10.53.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.469.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.0.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/office-js": "^1.0.587",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.5",
    "@typescript/native-preview": "^7.0.0-dev.20260525.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "oxlint": "^1.59.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.0"
  }
}
